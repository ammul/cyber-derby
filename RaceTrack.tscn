[sub_resource type="Shader" id="Shader_ilbxy"]
code = "shader_type canvas_item;

// Ermöglicht den Zugriff auf das, was hinter dem ColorRect liegt
uniform sampler2D SCREEN_TEXTURE : hint_screen_texture, filter_linear_mipmap;

// Regler für den Inspektor
uniform float curvature : hint_range(0.0, 0.1) = 0.06;
uniform float scanline_density : hint_range(100.0, 1000.0) = 1100.0;
uniform float scanline_opacity : hint_range(0.0, 0.5) = 0.5;

void fragment() {
    vec2 uv = SCREEN_UV;
    
    // 1. Bildschirmkrümmung (Fisheye-Effekt)
    // Wir berechnen die Verschiebung basierend auf der Entfernung zur Mitte
    vec2 centered_uv = uv * 2.0 - 1.0;
    // Compute radial distance in pixel space so the barrel is circular, not elliptical.
    // SCREEN_PIXEL_SIZE = vec2(1/w, 1/h), so y/x = w/h = aspect ratio.
    float aspect = SCREEN_PIXEL_SIZE.y / SCREEN_PIXEL_SIZE.x;
    vec2 pixel_cc = vec2(centered_uv.x * aspect, centered_uv.y);
    float r2 = dot(pixel_cc, pixel_cc);
    vec2 offset = centered_uv * r2 * curvature;
    uv += offset;
    
    // 2. Chromatic Aberration (Farbverschiebung)
    // Wir lesen die Farbkanäle leicht versetzt aus
    float r = texture(SCREEN_TEXTURE, uv + vec2(0.001, 0.0)).r;
    float g = texture(SCREEN_TEXTURE, uv).g;
    float b = texture(SCREEN_TEXTURE, uv - vec2(0.001, 0.0)).b;
    vec3 color = vec3(r, g, b);
    
    // 3. Scanlines
    // Erzeugt horizontale dunkle Streifen
    float scanline = sin(uv.y * scanline_density) * scanline_opacity;
    color -= scanline;
    
    // 4. Vignette (Dunkle Ränder)
    // Sorgt dafür, dass die Ecken abgerundet und dunkel wirken
    float vignette = uv.x * (1.0 - uv.x) * uv.y * (1.0 - uv.y) * 15.0;
    color *= pow(vignette, 0.25);
    
    // 5. Ergebnis ausgeben
    // Wenn UV außerhalb der 0-1 Range ist (durch Krümmung), zeichne Schwarz
    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) {
        COLOR = vec4(0.0, 0.0, 0.0, 1.0);
    } else {
        COLOR = vec4(color, 1.0);
    }
}
"

